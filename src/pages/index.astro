---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBadges from '../components/TrustBadges.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Catalog from '../components/Catalog.astro';
import BusinessTypes from '../components/BusinessTypes.astro';
import WhyNotSpotify from '../components/WhyNotSpotify.astro';
import LegalTrust from '../components/LegalTrust.astro';
import Pricing from '../components/Pricing.astro';
import Blog from '../components/Blog.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import CertificateModal from '../components/CertificateModal.astro';
---

<Layout title="MUUSICA - Música legal para tu negocio">
  <Header transparent={true} />
  <main>
    <Hero />
    <TrustBadges />
    <HowItWorks />
    <Catalog />
    <BusinessTypes />
    <WhyNotSpotify />
    <LegalTrust />
    <Pricing />
    <Blog />
    <FAQ />
    <FinalCTA />
  </main>
  <Footer />
  <CertificateModal />
</Layout>
