---

<section class="relative py-20 overflow-hidden border-t border-white/5" style="background: linear-gradient(180deg, #162038 0%, #1a1a2e 50%, #0A0A15 100%);">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-blue/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-primary-teal/10 rounded-full blur-[100px]"></div>
  </div>
  
  <div class="relative max-w-[1440px] mx-auto px-8 md:px-16 text-center">
    <div class="reveal max-w-2xl mx-auto">
      <!-- Content -->
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Empieza hoy con música 100% legal
      </h2>
      <p class="text-text-secondary text-lg mb-8">
        7 días gratis · Desde $175 MXN/locación
      </p>
      
      <!-- CTA Button -->
      <a href="https://play.muusica.com" class="btn-primary text-lg px-10 py-4 inline-flex">
        <span>Probar gratis</span>
        <i data-lucide="arrow-right" class="w-5 h-5 ml-2"></i>
      </a>
    </div>
  </div>
</section>
