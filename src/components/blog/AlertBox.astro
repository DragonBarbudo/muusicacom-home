---
// Alert/Callout box component for important information
interface Props {
  type?: 'warning' | 'info' | 'success' | 'danger';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  warning: {
    bg: 'bg-amber-500/10',
    border: 'border-amber-500/30',
    icon: 'alert-triangle',
    iconColor: 'text-amber-500',
    titleColor: 'text-amber-400'
  },
  info: {
    bg: 'bg-primary-blue/10',
    border: 'border-primary-blue/30',
    icon: 'info',
    iconColor: 'text-primary-blue',
    titleColor: 'text-primary-blue'
  },
  success: {
    bg: 'bg-primary-teal/10',
    border: 'border-primary-teal/30',
    icon: 'check-circle',
    iconColor: 'text-primary-teal',
    titleColor: 'text-primary-teal'
  },
  danger: {
    bg: 'bg-red-500/10',
    border: 'border-red-500/30',
    icon: 'alert-octagon',
    iconColor: 'text-red-500',
    titleColor: 'text-red-400'
  }
};

const style = styles[type];
---

<div class={`${style.bg} ${style.border} border rounded-xl p-5 my-8`}>
  <div class="flex gap-4">
    <div class={`${style.iconColor} flex-shrink-0 mt-0.5`}>
      <i data-lucide={style.icon} class="w-6 h-6"></i>
    </div>
    <div class="flex-1">
      {title && (
        <h4 class={`${style.titleColor} font-semibold mb-2`}>{title}</h4>
      )}
      <div class="text-text-secondary text-sm leading-relaxed [&>p]:mb-0">
        <slot />
      </div>
    </div>
  </div>
</div>
