---
// Styled quote/testimonial component
interface Props {
  author?: string;
  role?: string;
  variant?: 'default' | 'large' | 'card';
}

const { author, role, variant = 'default' } = Astro.props;
---

{variant === 'default' && (
  <blockquote class="my-8 relative pl-6 border-l-4 border-primary-teal">
    <div class="text-lg text-text-secondary italic leading-relaxed">
      <slot />
    </div>
    {author && (
      <footer class="mt-4 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-teal to-primary-blue"></div>
        <div>
          <cite class="text-white font-medium not-italic">{author}</cite>
          {role && <p class="text-text-tertiary text-sm">{role}</p>}
        </div>
      </footer>
    )}
  </blockquote>
)}

{variant === 'large' && (
  <blockquote class="my-10 text-center">
    <div class="text-primary-teal text-5xl font-serif leading-none mb-4">"</div>
    <div class="text-xl md:text-2xl text-white font-medium leading-relaxed max-w-2xl mx-auto">
      <slot />
    </div>
    {author && (
      <footer class="mt-6 flex items-center justify-center gap-3">
        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary-teal to-primary-blue"></div>
        <div class="text-left">
          <cite class="text-white font-medium not-italic">{author}</cite>
          {role && <p class="text-text-tertiary text-sm">{role}</p>}
        </div>
      </footer>
    )}
  </blockquote>
)}

{variant === 'card' && (
  <blockquote class="my-8 bg-gradient-to-br from-primary-teal/10 to-primary-blue/10 rounded-xl p-6 border border-primary-teal/20">
    <div class="flex gap-1 mb-3">
      {[...Array(5)].map(() => (
        <i data-lucide="star" class="w-4 h-4 text-amber-400 fill-amber-400"></i>
      ))}
    </div>
    <div class="text-text-secondary italic leading-relaxed">
      <slot />
    </div>
    {author && (
      <footer class="mt-4 flex items-center gap-3 pt-4 border-t border-white/10">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-teal to-primary-blue"></div>
        <div>
          <cite class="text-white font-medium not-italic">{author}</cite>
          {role && <p class="text-text-tertiary text-sm">{role}</p>}
        </div>
      </footer>
    )}
  </blockquote>
)}
