---
// Pros and Cons comparison component
interface Props {
  pros: string[];
  cons: string[];
  prosTitle?: string;
  consTitle?: string;
}

const { 
  pros, 
  cons, 
  prosTitle = 'Ventajas', 
  consTitle = 'Desventajas' 
} = Astro.props;
---

<div class="my-8 grid md:grid-cols-2 gap-4">
  <!-- Pros -->
  <div class="bg-primary-teal/10 rounded-xl p-5 border border-primary-teal/20">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-8 h-8 rounded-full bg-primary-teal/20 flex items-center justify-center">
        <i data-lucide="thumb-up" class="w-4 h-4 text-primary-teal"></i>
      </div>
      <h4 class="text-primary-teal font-semibold">{prosTitle}</h4>
    </div>
    <ul class="space-y-2">
      {pros.map((pro) => (
        <li class="flex gap-2 text-sm text-text-secondary">
          <i data-lucide="check" class="w-4 h-4 text-primary-teal flex-shrink-0 mt-0.5"></i>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Cons -->
  <div class="bg-red-500/10 rounded-xl p-5 border border-red-500/20">
    <div class="flex items-center gap-2 mb-4">
      <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center">
        <i data-lucide="thumb-down" class="w-4 h-4 text-red-400"></i>
      </div>
      <h4 class="text-red-400 font-semibold">{consTitle}</h4>
    </div>
    <ul class="space-y-2">
      {cons.map((con) => (
        <li class="flex gap-2 text-sm text-text-secondary">
          <i data-lucide="x" class="w-4 h-4 text-red-400 flex-shrink-0 mt-0.5"></i>
          <span>{con}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
