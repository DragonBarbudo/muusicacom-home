---
// Styled comparison table with good/bad highlighting
interface Props {
  title?: string;
  headers: string[];
  rows: Array<{
    label: string;
    values: Array<{ text: string; type?: 'good' | 'bad' | 'neutral' }>;
  }>;
  highlightColumn?: number;
}

const { title, headers, rows, highlightColumn } = Astro.props;
---

<div class="my-8 rounded-xl overflow-hidden border border-white/10">
  {title && (
    <div class="bg-white/5 px-5 py-3 border-b border-white/10">
      <h4 class="text-white font-semibold">{title}</h4>
    </div>
  )}
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-white/5">
          {headers.map((header, i) => (
            <th class={`px-5 py-4 text-left text-sm font-semibold ${
              highlightColumn === i ? 'text-primary-teal bg-primary-teal/10' : 'text-white'
            }`}>
              {header}
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row, rowIndex) => (
          <tr class={rowIndex % 2 === 0 ? 'bg-transparent' : 'bg-white/[0.02]'}>
            <td class="px-5 py-4 text-text-secondary font-medium border-t border-white/5">
              {row.label}
            </td>
            {row.values.map((val, colIndex) => (
              <td class={`px-5 py-4 border-t border-white/5 ${
                highlightColumn === colIndex + 1 ? 'bg-primary-teal/5' : ''
              }`}>
                <span class={`inline-flex items-center gap-2 ${
                  val.type === 'good' ? 'text-primary-teal' : 
                  val.type === 'bad' ? 'text-red-400' : 
                  'text-text-secondary'
                }`}>
                  {val.type === 'good' && <i data-lucide="check" class="w-4 h-4"></i>}
                  {val.type === 'bad' && <i data-lucide="x" class="w-4 h-4"></i>}
                  {val.text}
                </span>
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
