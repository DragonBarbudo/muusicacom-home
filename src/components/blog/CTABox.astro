---
// Call to action box for inline CTAs
interface Props {
  title: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  variant?: 'default' | 'gradient' | 'minimal';
}

const { 
  title, 
  description, 
  buttonText = 'Empezar ahora', 
  buttonLink = '/',
  variant = 'default' 
} = Astro.props;
---

{variant === 'default' && (
  <div class="my-10 bg-white/5 rounded-2xl p-8 border border-white/10 text-center">
    <h4 class="text-xl font-bold text-white mb-2">{title}</h4>
    {description && (
      <p class="text-text-secondary mb-6 max-w-md mx-auto">{description}</p>
    )}
    <a href={buttonLink} class="btn-primary inline-flex items-center gap-2">
      {buttonText}
      <i data-lucide="arrow-right" class="w-4 h-4"></i>
    </a>
  </div>
)}

{variant === 'gradient' && (
  <div class="my-10 bg-gradient-to-r from-primary-blue to-primary-purple rounded-2xl p-8 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
    <div class="relative">
      <h4 class="text-xl font-bold text-white mb-2">{title}</h4>
      {description && (
        <p class="text-white/80 mb-6 max-w-md mx-auto">{description}</p>
      )}
      <a href={buttonLink} class="inline-flex items-center gap-2 px-6 py-3 bg-white text-gray-900 font-semibold rounded-xl hover:bg-white/90 transition-colors">
        {buttonText}
        <i data-lucide="arrow-right" class="w-4 h-4"></i>
      </a>
    </div>
  </div>
)}

{variant === 'minimal' && (
  <div class="my-8 flex flex-col sm:flex-row items-center justify-between gap-4 p-5 bg-primary-teal/10 rounded-xl border border-primary-teal/20">
    <div>
      <h4 class="text-white font-semibold">{title}</h4>
      {description && (
        <p class="text-text-secondary text-sm">{description}</p>
      )}
    </div>
    <a href={buttonLink} class="btn-primary whitespace-nowrap flex-shrink-0">
      {buttonText}
    </a>
  </div>
)}
