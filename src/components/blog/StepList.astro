---
// Numbered step list with visual indicators
interface Props {
  title?: string;
  steps: Array<{
    title: string;
    description?: string;
  }>;
}

const { title, steps } = Astro.props;
---

<div class="my-8">
  {title && <h4 class="text-white font-semibold mb-6">{title}</h4>}
  <div class="space-y-4">
    {steps.map((step, i) => (
      <div class="flex gap-4">
        <div class="flex flex-col items-center">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-teal to-primary-blue flex items-center justify-center text-white font-bold flex-shrink-0">
            {i + 1}
          </div>
          {i < steps.length - 1 && (
            <div class="w-0.5 h-full bg-gradient-to-b from-primary-teal/50 to-transparent min-h-[24px] mt-2"></div>
          )}
        </div>
        <div class="pt-2 pb-6">
          <h5 class="text-white font-medium mb-1">{step.title}</h5>
          {step.description && (
            <p class="text-text-secondary text-sm">{step.description}</p>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
