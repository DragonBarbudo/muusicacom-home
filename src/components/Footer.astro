---
const navigationLinks = [
  { label: "Beneficios", href: "#beneficios" },
  { label: "Legal", href: "#legal" },
  { label: "Precios", href: "#precio" },
  { label: "Negocios", href: "#negocios" },
  { label: "Blog", href: "/blog" },
  { label: "FAQ", href: "#faq" },
];

const legalLinks = [
  { label: "Uso comercial permitido", href: "#" },
  { label: "Sin regalías", href: "#" },
  { label: "Certificado incluido", href: "#" },
];

const bottomLinks = [
  { label: "Términos", href: "#" },
  { label: "Privacidad", href: "#" },
  { label: "Contacto", href: "#" },
];
---

<footer class="py-16 px-8 md:px-16" style="background: linear-gradient(180deg, #0A0A15 0%, #050508 100%);">
  <div class="max-w-[1440px] mx-auto">
    <!-- Top section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Brand column -->
      <div>
        <a href="/" class="inline-block mb-4">
          <img src="/logo.svg" alt="Muusica" class="h-7 w-auto" />
        </a>
        <p class="text-text-secondary text-sm mb-6">
          Música legal para negocios.
        </p>
      </div>
      
      <!-- Navigation column -->
      <div>
        <h4 class="text-white font-semibold mb-4">Navegación</h4>
        <ul class="space-y-3">
          {navigationLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text-secondary text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Legal column -->
      <div>
        <h4 class="text-white font-semibold mb-4">Legal</h4>
        <ul class="space-y-3">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-text-secondary text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- CTA column -->
      <div>
        <h4 class="text-white font-semibold mb-4">¿Listo para empezar?</h4>
        <a href="https://play.muusica.com" class="btn-primary text-sm inline-flex mb-4">
          Probar gratis
        </a>
        <div class="space-y-2 text-sm">
          <a href="mailto:hola@muusica.com" class="text-text-secondary hover:text-white transition-colors flex items-center gap-2">
            <i data-lucide="mail" class="w-4 h-4"></i>
            hola@muusica.com
          </a>
        </div>
      </div>
    </div>
    
    <!-- Divider -->
    <div class="h-px bg-white/10 mb-8"></div>
    
    <!-- Bottom section -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-text-tertiary text-sm">
        © 2025 Muusica.com
      </p>
      <div class="flex items-center gap-6">
        {bottomLinks.map((link) => (
          <a href={link.href} class="text-text-tertiary text-sm hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
