---
const features = [
  "+10,000 canciones de todos los géneros",
  "Cientos de playlists curadas",
  "Certificado de licencia incluido",
  "Cancela cuando quieras",
];
---

<section id="precio" class="section bg-bg-page">
  <div class="max-w-[1440px] mx-auto">
    <!-- Header -->
    <div class="section-header reveal">
      <h2 class="section-title">Un plan simple</h2>
      <p class="section-subtitle max-w-2xl mx-auto">
        Sin contratos, sin letra pequeña
      </p>
    </div>
    
    <!-- Pricing Card -->
    <div class="reveal animation-delay-200 max-w-md mx-auto">
      <div class="relative group">
        <!-- Glow effect -->
        <div class="absolute -inset-1 bg-gradient-to-r from-primary-blue to-primary-teal rounded-3xl blur-xl opacity-30 group-hover:opacity-50 transition-opacity"></div>
        
        <!-- Card -->
        <div class="relative rounded-3xl p-10 border backdrop-blur-xl"
             style="background: rgba(10, 10, 21, 0.8); border-color: rgba(59, 130, 246, 0.25);">
          <!-- Badge -->
          <div class="text-center mb-6">
            <span class="px-4 py-1.5 rounded-full text-xs font-semibold text-primary-teal bg-primary-teal/10 border border-primary-teal/20 uppercase tracking-wider">
              Precio único
            </span>
          </div>
          
          <!-- Price -->
          <div class="text-center mb-8">
            <div class="flex items-baseline justify-center gap-1 mb-2">
              <span class="text-2xl text-text-secondary">$</span>
              <span class="text-6xl font-bold text-white">175</span>
              <span class="text-text-secondary">MXN/mes</span>
            </div>
            <p class="text-text-tertiary text-sm">por locación</p>
          </div>
          
          <!-- Features -->
          <ul class="space-y-4 mb-8">
            {features.map((feature) => (
              <li class="flex items-center gap-3">
                <div class="w-5 h-5 rounded-full bg-primary-teal/20 flex items-center justify-center flex-shrink-0">
                  <i data-lucide="check" class="w-3 h-3 text-primary-teal"></i>
                </div>
                <span class="text-text-secondary">{feature}</span>
              </li>
            ))}
          </ul>
          
          <!-- CTAs -->
          <div class="space-y-3">
            <a href="https://play.muusica.com" class="btn-primary w-full text-base py-4 inline-flex justify-center items-center">
              Probar gratis
            </a>
            <button class="btn-ghost w-full text-sm">
              Ver detalles
            </button>
          </div>
          
          <p class="text-center text-text-tertiary text-sm mt-4">
            7 días gratis · Sin tarjeta de crédito
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
